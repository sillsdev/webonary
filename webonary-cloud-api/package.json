{
  "name": "webonary-cloud-api",
  "version": "0.1.0",
  "bin": {
    "webonary-cloud-api": "bin/webonary-cloud-api.js"
  },
  "scripts": {
    "apidoc": "apidoc -f '^[^.]+\\.ts$' -i lambda/ -e lambda/__tests__ -e lambda/node_modules  -o lambda_api_doc/",
    "build": "npx tsc",
    "cdk": "env-cmd npx aws-cdk@2.x",
    "deploy": "npm run test && npm run cdk deploy",
    "deploy-local": "npm run env-cmd cdk synth --no-staging >| template.yaml && sam local start-api",
    "migrate": "cd mongo_utils && env-cmd -f ../.env mongo-migrate",
    "post-legacy": "env-cmd ts-node -r tsconfig-paths/register tools/post-legacy.ts",
    "test": "tsc && jest --detectOpenHandles --runInBand --force-exit",
    "test-coverage": "tsc && jest --detectOpenHandles --runInBand --force-exit --collectCoverage",
    "watch": "tsc -w"
  },
  "devDependencies": {
    "@aws-cdk/assert": "^2.32.0",
    "@types/cheerio": "^0.22",
    "@types/jest": "^28.1.1",
    "@types/mime-types": "^2.1.1",
    "@types/node": "^22.0",
    "@types/parse5": "^6.0.3",
    "@types/sanitize-html": "^2.6.2",
    "aws-cdk-lib": "^2.1",
    "constructs": "^10.0.0",
    "env-cmd": "^10.1.0",
    "esbuild": "^0.25",
    "form-data": "^4.0.0",
    "jest": "^30.1",
    "parse5": "^7.0.0",
    "prettier": "^3.6",
    "ts-jest": "^29.4",
    "ts-node": "^10.8",
    "tsconfig-paths": "^4.0.0",
    "typescript": "^5.9"
  },
  "dependencies": {
    "aws-cdk-lib": "^2.32.0",
    "axios": "^1.6",
    "cheerio": "^1.1.2",
    "constructs": "^10.0.0",
    "mime-types": "^2.1.35",
    "mongodb": "^4.17.1",
    "npm-check-updates": "^19.3.1"
  }
}
